function generate_coin_pdf_by_ids($post_ids) {

    global $wpdb;

    if (empty($post_ids)) {
        wp_die('هیچ سکه‌ای انتخاب نشده است');
    }

    $ids_placeholders = implode(',', array_fill(0, count($post_ids), '%d'));

   $coins = [];

foreach ($post_ids as $post_id) {

    $serial = get_post_meta($post_id, '_coin_serial', true);

    if (!$serial) {
        continue;
    }

    $coin_type = get_post_meta($post_id, 'coin_type', true);

    $coins[] = (object) [
        'serial' => $serial,
        'coin_type' => $coin_type
    ];
}

    if (empty($coins)) {
        wp_die('هیچ سکه‌ای یافت نشد');
    }

    require_once __DIR__ . '/fpdf/fpdf.php';
    require_once __DIR__ . '/phpqrcode/qrlib.php';

    while (ob_get_level()) {
        ob_end_clean();
    }

    $pdf = new FPDF('P', 'mm', 'A4');

    $pdf->SetMargins(5, 5, 5);

    $pdf->AddPage();

    $pdf->SetAutoPageBreak(false);

    $pdf->SetFont('Arial', '', 5);

    // تنظیمات جدول
    $startX = 8;
    $startY = 8;

    $qrSize = 25; // حدود 1 اینچ

    $cellWidth = 38;
    $cellHeight = 45;

    $cols = 5;

    $i = 0;

    foreach ($coins as $coin) {

        $serial = trim($coin->serial);

        $coin_type = trim($coin->coin_type);

        $url = site_url('/verify-coin/?serial=' . rawurlencode($serial));

        $upload_dir = wp_upload_dir();

        $qr_dir = $upload_dir['basedir'] . '/coin_qr_codes';

        if (!file_exists($qr_dir)) {
            wp_mkdir_p($qr_dir);
        }

        $qr_file = $qr_dir . '/qr_' . md5($serial) . '.png';

        if (!file_exists($qr_file)) {
            QRcode::png($url, $qr_file, QR_ECLEVEL_L, 4);
        }

        $row = floor($i / $cols) % 6;

        $col = $i % $cols;

        $x = $startX + ($col * $cellWidth);

        $y = $startY + ($row * $cellHeight);

        // صفحه جدید بعد از 30 آیتم
        if ($i > 0 && $i % 30 == 0) {

            $pdf->AddPage();

            $row = 0;
            $col = 0;

            $x = $startX;
            $y = $startY;
        }

        // QR
        if (file_exists($qr_file)) {

            $pdf->Image($qr_file, $x + 5, $y, $qrSize, $qrSize);

        }

        // شماره سریال
        $pdf->SetXY($x, $y + 27);

        $pdf->Cell(38, 3, $serial, 0, 0, 'C');

        // نوع سکه
        $pdf->SetXY($x, $y + 31);

        $pdf->Cell(38, 3, $coin_type, 0, 0, 'C');

        // متن تایید اصالت
        $pdf->SetXY($x, $y + 35);

        $pdf->Cell(38, 3, 'Authenticity Verified', 0, 0, 'C');

        $i++;
    }

    $pdf->Output('D', 'coins-qr.pdf');

    exit;
}






// ذخیره وضعیت چاپ هنگام آپدیت پست
add_action('save_post', 'gca_save_print_status_meta');
function gca_save_print_status_meta($post_id) {
    if (!isset($_POST['gca_print_nonce']) || !wp_verify_nonce($_POST['gca_print_nonce'], 'gca_save_print_status')) {
        return;
    }
    if (defined('DOING_AUTOSAVE') && DOING_AUTOSAVE) {
        return;
    }
    if (isset($_POST['post_type']) && 'gold_coin' == $_POST['post_type']) {
        if (!current_user_can('edit_post', $post_id)) {
            return;
        }
    }

    $is_printed = isset($_POST['coin_is_printed']) ? '1' : '0';
    update_post_meta($post_id, '_coin_is_printed', $is_printed);
}

