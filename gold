// 3. صفحه تولید خودکار سکه
function gca_generate_coins_page() {
    if (isset($_POST['gca_generate'])) {
        $coin_type = sanitize_text_field($_POST['coin_type']);
        $quantity = intval($_POST['quantity']);
        $prefix = '';

        switch ($coin_type) {
            case 'full': $prefix = 'F-'; $type_name = 'تمام سکه'; break;
            case 'half': $prefix = 'H-'; $type_name = 'نیم سکه'; break;
            case 'quarter': $prefix = 'Q-'; $type_name = 'ربع سکه'; break;
            case '1gram': $prefix = 'G-'; $type_name = 'سکه یک گرمی'; break;
        }

        for ($i = 0; $i < $quantity; $i++) {
            $random_string = strtoupper(substr(md5(uniqid(mt_rand(), true)), 0, 8));
            $serial_number = $prefix . $random_string;
            
            $post_id = wp_insert_post(array(
                'post_title'  => $serial_number,
                'post_type'   => 'gold_coin',
                'post_status' => 'publish'
            ));

            if ($post_id) {
                // *** اصلاح شد: استفاده از _coin_serial برای هماهنگی ***
                update_post_meta($post_id, '_coin_serial', $serial_number);
                update_post_meta($post_id, 'coin_type', $type_name);
                update_post_meta($post_id, '_coin_is_printed', '0'); // پیش‌فرض: چاپ نشده
                
               $verify_link = site_url('/verify-coin/?serial=' . rawurlencode($serial_number));
$qr_url = "https://api.qrserver.com/v1/create-qr-code/?size=300x300&data=" . urlencode($verify_link);


                update_post_meta($post_id, 'qr_code_url', $qr_url);
            }
        }
        echo '<div class="notice notice-success"><p>' . $quantity . ' سکه جدید با موفقیت تولید شد.</p></div>';
    }
    ?>
    <div class="wrap">
        <h1>تولید خودکار سکه</h1>
        <form method="POST">
            <table class="form-table">
                <tr>
                    <th><label for="coin_type">نوع سکه</label></th>
                    <td>
                        <select name="coin_type" id="coin_type">
                            <option value="full">تمام سکه (F)</option>
                            <option value="half">نیم سکه (H)</option>
                            <option value="quarter">ربع سکه (Q)</option>
                            <option value="1gram">سکه یک گرمی (G)</option>
                        </select>
                    </td>
                </tr>
                <tr>
                    <th><label for="quantity">تعداد</label></th>
                    <td><input type="number" name="quantity" id="quantity" value="1" min="1" max="100"></td>
                </tr>
            </table>
            <p class="submit"><input type="submit" name="gca_generate" class="button button-primary" value="تولید سکه‌ها"></p>
        </form>
    </div>
    <?php
}

// 4. ابزار همگام‌سازی
function gca_sync_old_data_page() {
    if (isset($_POST['gca_sync'])) {
        $args = array(
            'post_type'      => 'gold_coin',
            'posts_per_page' => -1,
            'meta_query'     => array(
                array(
                    'key'     => 'qr_code_url',
                    'compare' => 'NOT EXISTS'
                )
            )
        );
        $coins = get_posts($args);
        $count = 0;
        foreach ($coins as $coin) {
            // *** اصلاح شد: استفاده از _coin_serial برای هماهنگی ***
            $serial_number = get_post_meta($coin->ID, '_coin_serial', true);
            if (empty($serial_number)) {
                $serial_number = $coin->post_title;
                update_post_meta($coin->ID, '_coin_serial', $serial_number);
            }
            $verify_link = site_url('/verify-coin/?serial=' . rawurlencode($serial_number));
$qr_url = "https://api.qrserver.com/v1/create-qr-code/?size=300x300&data=" . urlencode($verify_link);


            update_post_meta($coin->ID, 'qr_code_url', $qr_url);
            $count++;
        }
        echo '<div class="notice notice-success"><p>تعداد ' . $count . ' QR کد برای داده‌های قدیمی ساخته شد.</p></div>';
    }
    ?>
    <div class="wrap">
        <h1>بروزرسانی داده‌های قبلی</h1>
        <p>تولید QR کد برای داده‌های ایمپورت شده که فاقد آن هستند.</p>
        <form method="POST">
            <p class="submit"><input type="submit" name="gca_sync" class="button button-primary" value="تولید QR کد"></p>
        </form>
    </div>
    <?php
}

