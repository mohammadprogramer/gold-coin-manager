    switch ($column) {
        case 'coin_type':
            echo esc_html(get_post_meta($post_id, 'coin_type', true));
            break;
        case 'qr_preview':
            $qr = get_post_meta($post_id, 'qr_code_url', true);
            if ($qr) {
                echo '<img src="' . esc_url($qr) . '" style="width:50px;height:50px;" />';
            } else {
                echo '-';
            }
            break;
        case 'is_printed':
            $printed = get_post_meta($post_id, '_coin_is_printed', true);
            if ($printed == '1') {
                echo '<span style="color:green; font-weight:bold;">✅ چاپ شده</span>';
            } else {
                echo '<span style="color:red;">❌ چاپ نشده</span>';
            }
            break;
    }
}


