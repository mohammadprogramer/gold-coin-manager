function verify_coin_shortcode_handler() {
    global $wpdb;

    // گرفتن مقدار سریال از URL
    $serial = isset($_GET['serial']) ? sanitize_text_field($_GET['serial']) : '';

    if (!$serial) {
        return '<p>شماره سریال وارد نشده است.</p>';
    }

    // جستجو در جدول wp_postmeta برای سریال
    $table_name = $wpdb->prefix . 'postmeta';
    $query = $wpdb->prepare(
        "SELECT post_id FROM $table_name WHERE meta_key = %s AND meta_value = %s",
        '_coin_serial',
        $serial
    );

    $post_id = $wpdb->get_var($query);

    if ($post_id) {
        return "<p>سکه با شماره سریال <strong>{$serial}</strong> تایید شد.</p>";
    } else {
        return "<p>سکه با شماره سریال <strong>{$serial}</strong> یافت نشد یا اصالت آن تایید نمی‌شود.</p>";
    }
}

add_shortcode('verify_coin', 'verify_coin_shortcode_handler');



